generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL") // keep if you're using env
}

enum WorkspaceRole {
  OWNER
  ADMIN
  AGENT
  VIEWER
}

enum ConversationChannel {
  PHONE
  CHAT
}

model User {
  id        String   @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships WorkspaceMember[]
}

model Workspace {
  id           String   @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  name         String

  // Keys are always generated by DB so Studio shows "(default value)"
  workspaceKey String   @unique @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  webhookKey   String   @unique @db.Uuid @default(dbgenerated("gen_random_uuid()"))

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       WorkspaceMember[]
  contacts      Contact[]
  conversations Conversation[]
  events        Event[]
}

model WorkspaceMember {
  id          String        @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  workspaceId String        @db.Uuid
  userId      String        @db.Uuid
  role        WorkspaceRole @default(AGENT)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
}

model Contact {
  id          String   @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  workspaceId String   @db.Uuid
  name        String?
  email       String?
  phone       String?
  igHandle    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  events        Event[]

  // NOTE: multiple NULLs are allowed; emails/phones/handles should be normalized in code
  @@unique([workspaceId, email])
  @@unique([workspaceId, phone])
  @@unique([workspaceId, igHandle])
  @@index([workspaceId])
}

model Conversation {
  id          String              @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  workspaceId String              @db.Uuid
  contactId   String              @db.Uuid
  channel     ConversationChannel
  source      String?
  startedAt   DateTime            @default(now())
  endedAt     DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  events    Event[]

  @@index([workspaceId])
  @@index([contactId])
  @@index([workspaceId, contactId])
}

model Event {
  id             String   @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  workspaceId    String   @db.Uuid
  contactId      String?  @db.Uuid
  conversationId String?  @db.Uuid

  type            String
  source          String?
  occurredAt      DateTime
  externalEventId String?
  payload         Json
  receivedAt      DateTime @default(now())

  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact      Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversation Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  // Don't use @@unique([workspaceId, externalEventId]) while externalEventId is optional;
  // do de-dupe in code for Phase 1 (or add a partial unique index via SQL migration).
  @@index([workspaceId, occurredAt])
  @@index([contactId])
  @@index([conversationId])
  @@index([workspaceId, externalEventId])
}