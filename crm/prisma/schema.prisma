generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  AGENT
  VIEWER
}

enum VoiceflowChannel {
  CHAT
  PHONE
  WHATSAPP
  INSTAGRAM
  MESSENGER
  WEB
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  WON
  LOST
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships WorkspaceMember[]
}

model Workspace {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  workspaceKey String @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Used for inbound lead capture/webhooks (one per workspace)
  webhookKey String? @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members    WorkspaceMember[]
  voiceflow  VoiceflowConnection[]
  leads      Lead[]
  leadEvents LeadEvent[]
}

model WorkspaceMember {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String        @db.Uuid
  userId      String        @db.Uuid
  role        WorkspaceRole @default(AGENT)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
}

/**
 * One workspace can have multiple Voiceflow connections.
 * Example: 1 chatbot project + 1 phone caller project, each with different IDs/keys.
 * SECURITY NOTE:
 * Storing API keys in plaintext in Postgres is not ideal.
 * In practice, you store ENCRYPTED values in `apiKeyCiphertext` and decrypt server-side.
 */
model VoiceflowConnection {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String @db.Uuid

  // Human label for you + client
  name String

  // Voiceflow identifiers
  projectId   String
  environment String? // e.g. "production" if you need it later

  // Store encrypted key (recommended). If you insist on plaintext, rename to apiKey and accept risk.
  apiKeyCiphertext String

  // Optional: mark which connection is used for what
  channel VoiceflowChannel @default(CHAT)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads      Lead[]
  leadEvents LeadEvent[]

  @@unique([workspaceId, projectId, name])
  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@index([workspaceId, projectId])
}

model Lead {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String   @db.Uuid
  connectionId   String   @db.Uuid
  name           String
  phone          String
  email          String?
  message        String
  source         String   @default("voiceflow")
  lastCapturedAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace  Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connection VoiceflowConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  events     LeadEvent[]

  @@unique([workspaceId, phone])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, connectionId])
  @@index([workspaceId, email])
}

model LeadEvent {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId  String   @db.Uuid
  leadId       String   @db.Uuid
  connectionId String   @db.Uuid
  type         String
  occurredAt   DateTime
  payload      Json
  createdAt    DateTime @default(now())

  workspace  Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead       Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  connection VoiceflowConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([workspaceId, occurredAt])
  @@index([leadId])
  @@index([workspaceId, connectionId])
}
